{
  "manifest_version": 3,
  "name": "DeepShield",
  "version": "1.0",
  "permissions": ["contextMenus", "activeTab"],
  "host_permissions": ["http://127.0.0.1:5000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.instagram.com/*"],
      "js": ["content.js"]
    }
  ]
}